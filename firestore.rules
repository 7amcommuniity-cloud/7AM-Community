rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // --- Enquiries ---
    match /enquiries/{enquiryId} {
      allow create: if isValidId(enquiryId) 
        && isValidEnquiry(incoming());
      
      function isValidEnquiry(data) {
        return data.keys().hasAll(['name', 'email', 'message', 'createdAt'])
          && data.keys().size() <= 6
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.email is string && data.email.size() <= 100
          && data.message is string && data.message.size() > 0 && data.message.size() <= 1000
          && data.createdAt == request.time
          && (data.get('club', '') is string && data.get('club', '').size() <= 100);
      }
    }

    // --- Registrations ---
    match /registrations/{registrationId} {
      allow create: if isValidId(registrationId)
        && isValidRegistration(incoming());

      function isValidRegistration(data) {
        return data.keys().hasAll(['name', 'email', 'phone', 'gender', 'event', 'transactionId', 'createdAt', 'status'])
          && data.keys().size() == 8
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.email is string && data.email.size() <= 100
          && data.phone is string && data.phone.size() == 10
          && data.gender is string && data.gender.size() <= 20
          && data.event is string && data.event.size() <= 200
          && data.transactionId is string && data.transactionId.size() > 0 && data.transactionId.size() <= 100
          && data.status == 'pending'
          && data.createdAt == request.time;
      }
    }

    // --- New Registrations 2025 ---
    match /events_2025_new/{registrationId} {
      allow create: if isValidId(registrationId)
        && isValidNewRegistration(incoming());
      
      // Allow list for ordering verification (if added later)
      allow list: if true; 

      function isValidNewRegistration(data) {
        return data.keys().hasAll(['name', 'email', 'phone', 'gender', 'event', 'transactionId', 'createdAt', 'registeredAt', 'status'])
          && data.keys().size() == 9
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.email is string && data.email.size() <= 100
          && data.phone is string && data.phone.size() == 10
          && data.gender is string && data.gender.size() <= 20
          && data.event is string && data.event.size() <= 200
          && data.transactionId is string && data.transactionId.size() > 0 && data.transactionId.size() <= 100
          && data.status == 'pending'
          && data.createdAt == request.time
          && data.registeredAt == request.time;
      }
    }

    // --- Starbucks Grande Run Registrations ---
    match /event_starbucks/{registrationId} {
      allow create: if isValidId(registrationId)
        && isValidNewRegistration(incoming());
      
      allow list: if true;

      function isValidNewRegistration(data) {
        return data.keys().hasAll(['name', 'email', 'phone', 'gender', 'event', 'transactionId', 'createdAt', 'registeredAt', 'status'])
          && data.keys().size() == 9
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.email is string && data.email.size() <= 100
          && data.phone is string && data.phone.size() == 10
          && data.gender is string && data.gender.size() <= 20
          && data.event is string && data.event.size() <= 200
          && data.transactionId is string && data.transactionId.size() > 0 && data.transactionId.size() <= 100
          && data.status == 'pending'
          && data.createdAt == request.time
          && data.registeredAt == request.time;
      }
    }

    // --- Murphies Sunday Reset Registrations ---
    match /event_murphies_sunday_reset/{registrationId} {
      allow create: if isValidId(registrationId)
        && isValidNewRegistration(incoming());
      
      allow list: if true;

      function isValidNewRegistration(data) {
        return data.keys().hasAll(['name', 'email', 'phone', 'gender', 'event', 'transactionId', 'createdAt', 'registeredAt', 'status'])
          && data.keys().size() == 9
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.email is string && data.email.size() <= 100
          && data.phone is string && data.phone.size() == 10
          && data.gender is string && data.gender.size() <= 20
          && data.event is string && data.event.size() <= 200
          && data.transactionId is string && data.transactionId.size() > 0 && data.transactionId.size() <= 100
          && data.status == 'pending'
          && data.createdAt == request.time
          && data.registeredAt == request.time;
      }
    }
  }
}
