{
  "entities": {
    "Enquiry": {
      "title": "Enquiry",
      "description": "User enquiry from the contact form",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "club": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "Registration": {
      "title": "Registration",
      "description": "User registration for a run event",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "gender": { "type": "string" },
        "event": { "type": "string" },
        "transactionId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "verified"] }
      },
      "required": ["name", "email", "phone", "gender", "event", "transactionId", "createdAt", "status"]
    }
  },
  "firestore": {
    "/enquiries/{enquiryId}": {
      "schema": "Enquiry",
      "description": "Collection of user enquiries"
    },
    "/registrations/{registrationId}": {
      "schema": "Registration",
      "description": "Collection of event registrations"
    }
  }
}
